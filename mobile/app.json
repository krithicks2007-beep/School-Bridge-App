{
  "expo": {
    "name": "School Bridge",
    "slug": "school-parent-app",
    "version": "1.0.0",
    "scheme": "school-bridge",
    "orientation": "portrait",
    "icon": "./assets/custom-icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow School App to access your photos to upload student profile picture.",
          "cameraPermission": "Allow School App to use camera to take student profile picture."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.schoolbridgeapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/custom-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.schoolbridgeapp.mobile"
    },
    "extra": {
      "eas": {
        "projectId": "ee7fdf83-a2e9-4018-89d2-b59fb54fcb98"
      }
    }
  }
}
